{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loesungerdechris-lang/upgraded-guacamole/schemas/evidence.schema.json",
  "title": "SENTINEL Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "issued_at",
    "source",
    "artifact_hash",
    "previous_hash",
    "policy_id",
    "decision",
    "signature"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "evidence_id": {
      "type": "string",
      "minLength": 8
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "artifact_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "previous_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "deny", "review", "quarantine"]
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "key_id", "value"],
      "properties": {
        "alg": {
          "type": "string",
          "enum": ["ES256", "EdDSA"]
        },
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 16
        }
      }
    }
  }
}
